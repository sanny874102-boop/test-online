<!DOCTYPE html>
<html lang="zh-TW">
<head>
  <meta charset="UTF-8">
  <title>🚀 全班秒刷 (電腦大螢幕版)</title>
  <script src="https://cdn.jsdelivr.net/gh/jcmellado/js-aruco@master/src/cv.js"></script>
  <script src="https://cdn.jsdelivr.net/gh/jcmellado/js-aruco@master/src/aruco.js"></script>
  <style>
    body { font-family: sans-serif; background: #2c3e50; color: white; text-align: center; padding: 20px; margin: 0; }
    #question-area { background: #fff; color: #333; border-radius: 20px; padding: 40px; margin-bottom: 20px; box-shadow: 0 10px 30px rgba(0,0,0,0.5); min-height: 250px; }
    #q-text { font-size: 48px; font-weight: bold; color: #d35400; }
    #options { font-size: 32px; text-align: left; display: inline-block; line-height: 1.8; margin-top: 20px; }
    .btn { font-size: 24px; padding: 15px 40px; cursor: pointer; border-radius: 50px; border: none; background: #f39c12; color: white; font-weight: bold; margin: 5px; }
    video { width: 480px; border-radius: 15px; border: 4px solid #27ae60; margin-top: 20px; background: #000; }
    #res { font-size: 24px; margin-top: 15px; font-weight: bold; }
  </style>
</head>
<body>

<div id="question-area">
  <div id="q-text">請點擊「抽題」開始</div>
  <div id="options"></div>
</div>

<button class="btn" onclick="drawQ()">🎲 1. 從試算表抽題</button>
<button class="btn" id="camBtn" onclick="startCamera()" style="background:#27ae60;">🎥 2. 開啟鏡頭掃描</button>

<br>
<video id="v" autoplay playsinline muted></video>
<canvas id="c" style="display:none"></canvas>
<div id="res">🟢 系統連線中...</div>

<script>
  // 🌟 使用您正確的 Apps Script 網址
  const API_URL = "https://script.google.com/macros/s/AKfycbwRLe2VvIOZLRlQVNy2VM6eKR13gYDc2mXDpeZuZNL9tDtmdVBkHJZAXeyuDQ9u4n0aVQ/exec";

  var v = document.getElementById('v'), c = document.getElementById('c'), ctx = c.getContext('2d'), rD = document.getElementById('res');
  var detector, scanActive = false, currentAns = "", scannedMap = {};

  function drawQ() {
    rD.innerHTML = "⏳ 正在抽題...";
    fetch(API_URL + "?action=getQuiz&t=" + Date.now()).then(res => res.json()).then(data => {
      const q = data[0];
      document.getElementById('q-text').innerText = "題目：" + q.q;
      document.getElementById('options').innerHTML = "(A) "+q.a+"<br>(B) "+q.b+"<br>(C) "+q.c+"<br>(D) "+q.d;
      currentAns = q.ans;
      scannedMap = {};
      rD.innerHTML = "✅ 抽題成功！請開啟鏡頭。";
    });
  }

  async function startCamera() {
    try {
      detector = new AR.Detector();
      // 🌟 電腦版通常使用 user (視訊鏡頭)
      const stream = await navigator.mediaDevices.getUserMedia({ video: { facingMode: "user" } });
      v.srcObject = stream;
      scanActive = true;
      document.getElementById('camBtn').style.background = "#e74c3c";
      document.getElementById('camBtn').innerText = "🛑 停止掃描";
      tick();
    } catch (err) {
      rD.innerHTML = "❌ 無法啟動鏡頭：" + err.message + "<br>請檢查是否允許瀏覽器使用相機。";
      console.error(err);
    }
  }

  function tick() {
    if(!scanActive) return;
    if(v.readyState === v.HAVE_ENOUGH_DATA){
      c.width = v.videoWidth; c.height = v.videoHeight;
      ctx.drawImage(v, 0, 0, c.width, c.height);
      var markers = detector.detect(ctx.getImageData(0, 0, c.width, c.height));
      if(markers.length > 0){
        var id = markers[0].id;
        if(!scannedMap[id]){
          scannedMap[id] = true;
          var ans = ["A","B","C","D"][markers[0].rotation];
          fetch(`${API_URL}?action=record&id=${id}&ans=${ans}&t=${Date.now()}`, {mode:'no-cors'});
          rD.innerHTML = (ans === currentAns) ? `✅ ${id} 號答對了！` : `❌ ${id} 號選了 ${ans}`;
          setTimeout(() => { delete scannedMap[id]; }, 3000);
        }
      }
    }
    requestAnimationFrame(tick);
  }
</script>
</body>
</html>
